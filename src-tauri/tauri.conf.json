{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lodestar",
  "version": "0.1.0",
  "identifier": "app.lodestar.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "lodestar",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "appimage", "nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "category": "DeveloperTool",
    "shortDescription": "Editor local-first de bases de conocimiento OKF",
    "longDescription": "lodestar es un editor local-first de bases de conocimiento OKF: directorios de Markdown con frontmatter YAML, con verificación de conformidad, grafo de enlaces, búsqueda e integración git.",
    "copyright": "© 2026 dbareagimeno",
    "publisher": "dbareagimeno",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      }
    }
  }
}
